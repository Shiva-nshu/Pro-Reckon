# Copy this file to .env and fill in values. See docs/ENV_SETUP_GUIDE.md for where to register/get each one.
#
# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL=http://localhost:3000

# Firebase (Firestore) – path to service account JSON (in project root)
GOOGLE_APPLICATION_CREDENTIALS="serviceAccountKey.json"

# Option B: Inline credentials (e.g. for hosted environments)
# FIREBASE_PROJECT_ID="your-project-id"
# FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# (Email sending is disabled — app focuses on finding & showing conversion-ready leads.)

# Lead discovery: comma-separated domains to fetch via Hunter.io (e.g. stripe.com,github.com)
LEAD_SOURCE_DOMAINS="domain1.com,domain2.com"

# Enrichment API (Hunter.io) – required for enrichment and lead discovery
ENRICHMENT_API_KEY="YOUR_ENRICHMENT_API_KEY"

# Scraper (optional)
PROXY_LIST="http://proxy1:8080,http://proxy2:8080"
