# Copy this file to .env and fill in values. See docs/ENV_SETUP_GUIDE.md for where to register/get each one.
#
# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL=http://localhost:3000

# Firebase (Firestore) – path to service account JSON (in project root)
GOOGLE_APPLICATION_CREDENTIALS="serviceAccountKey.json"

# Option B: Inline credentials (e.g. for hosted environments)
# FIREBASE_PROJECT_ID="your-project-id"
# FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# (Email sending is disabled — app focuses on finding & showing conversion-ready leads.)

# Lead discovery — choose one or both:
# 1) Discover by ICP (finds companies + people to pitch to): set country code (e.g. IN = India) and optional industries.
LEAD_DISCOVER_COUNTRY="IN"
LEAD_DISCOVER_INDUSTRIES="Manufacturing,Real Estate,Construction,Financial Services"

# 2) Or manual list of company domains (if Discover not used or as fallback).
LEAD_SOURCE_DOMAINS=""

# Demo scoring: cities that get +10 (comma-separated). Default: ahmedabad,mumbai,delhi,pune,bangalore,...
# TARGET_CITIES="ahmedabad,mumbai,delhi"

# Enrichment API (Hunter.io) – required for enrichment and lead discovery
ENRICHMENT_API_KEY="YOUR_ENRICHMENT_API_KEY"

# Scraper (optional)
PROXY_LIST="http://proxy1:8080,http://proxy2:8080"
